---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Vraj Patel',
	description = 'Information Systems Engineer & Machine Learning Researcher — Boulder, CO.',
} = Astro.props;

const nav = [
	{ href: '/', label: 'Home' },
	{ href: '/experience', label: 'Experience' },
	{ href: '/projects', label: 'Projects' },
] as const;
---

<!doctype html>
<html lang="en" class="min-h-full scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body class="flex min-h-screen flex-col bg-slate-950 font-sans text-slate-300 selection:bg-indigo-500/30">
		<div class="fixed inset-0 -z-10 h-full w-full bg-[radial-gradient(#1e293b_1px,transparent_1px)] [background-size:24px_24px] opacity-20"></div>
		<div class="fixed inset-0 -z-10 h-full w-full">
			<div class="absolute left-0 top-0 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-indigo-500/10 blur-[120px]"></div>
		</div>

		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-slate-900 focus:px-4 focus:py-2 focus:text-slate-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:underline"
			>Skip to content</a
		>

		<header class="sticky top-0 z-40 w-full border-b border-white/5 bg-slate-950/60 backdrop-blur-xl">
			<div class="mx-auto flex h-16 max-w-4xl items-center justify-between px-4 sm:px-6">
				<a href="/" class="group flex items-center gap-2 no-underline outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-950 rounded-md">
					<div class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 group-hover:bg-indigo-500/20 group-hover:text-indigo-300 transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>
					</div>
					<span class="font-mono text-sm font-semibold tracking-tight text-slate-200">VRAJ PATEL</span>
				</a>
				<nav aria-label="Primary" class="hidden md:flex items-center gap-1">
					{
						nav.map(({ href, label }) => (
							<a
								href={href}
								class:list={[
									'rounded-md px-3 py-2 text-sm font-medium transition-all outline-none focus-visible:ring-2 focus-visible:ring-indigo-500',
									Astro.url.pathname === href || (href !== '/' && Astro.url.pathname.startsWith(href))
										? 'bg-white/10 text-white shadow-sm ring-1 ring-white/10'
										: 'text-slate-400 hover:bg-white/5 hover:text-slate-200',
								]}
							>
								{label}
							</a>
						))
					}
					<a
						href="/VrajResume_Master.docx"
						target="_blank"
						rel="noopener noreferrer"
						class="ml-2 rounded-md bg-indigo-500/10 px-4 py-2 text-sm font-medium text-indigo-300 transition-all hover:bg-indigo-500/20 hover:text-indigo-200 outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 ring-1 ring-indigo-500/20"
					>
						Resume
					</a>
				</nav>
                {/* Mobile nav simple fallback */}
                <nav class="md:hidden flex gap-2">
                    <a href="/experience" class="text-sm text-slate-400 hover:text-slate-200">Exp</a>
                    <a href="/projects" class="text-sm text-slate-400 hover:text-slate-200">Proj</a>
                    <a href="/VrajResume_Master.docx" class="text-sm text-indigo-400 hover:text-indigo-300">Resume</a>
                </nav>
			</div>
		</header>

		<main id="main" class="mx-auto w-full max-w-4xl flex-1 px-4 py-16 sm:px-6 md:py-24">
			<slot />
		</main>

		<footer class="mt-auto border-t border-white/5 bg-slate-950/50 py-12">
			<div class="mx-auto flex max-w-4xl flex-col items-center justify-between gap-6 px-4 sm:flex-row sm:px-6">
				<p class="font-mono text-sm text-slate-500">
					© {new Date().getFullYear()} Vraj Patel. Boulder, CO.
				</p>
				<div class="flex gap-4">
					<a href="https://www.linkedin.com/in/vrajmp/" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-slate-300 transition-colors">
						<span class="sr-only">LinkedIn</span>
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
					</a>
                    <a href="mailto:vrajmp999@gmail.com" class="text-slate-500 hover:text-slate-300 transition-colors">
						<span class="sr-only">Email</span>
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
					</a>
				</div>
			</div>
		</footer>
	</body>
</html>