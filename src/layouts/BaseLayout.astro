---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Vraj Patel',
	description = 'Information Systems Engineer & Machine Learning Researcher — Boulder, CO.',
} = Astro.props;

const nav = [
	{ href: '/', label: 'Home' },
	{ href: '/experience', label: 'Experience' },
	{ href: '/projects', label: 'Projects' },
] as const;
---

<!doctype html>
<html lang="en" class="min-h-full">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body class="flex min-h-screen flex-col">
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-slate-900 focus:px-3 focus:py-2 focus:underline"
			>Skip to content</a
		>

		<header class="sticky top-0 z-40 border-b border-slate-800/80 bg-slate-950/80 backdrop-blur-md">
			<div
				class="mx-auto flex max-w-3xl flex-wrap items-center justify-between gap-4 px-4 py-4 sm:px-6"
			>
				<a href="/" class="group no-underline">
					<span class="font-mono text-xs tracking-widest text-slate-500 uppercase">Vraj Patel</span>
				</a>
				<nav aria-label="Primary" class="flex flex-wrap items-center gap-1 sm:gap-2">
					{
						nav.map(({ href, label }) => (
							<a
								href={href}
								class:list={[
									'rounded-md px-2.5 py-1.5 text-sm font-medium no-underline transition-colors',
									Astro.url.pathname === href
										? 'bg-slate-900 text-slate-100'
										: 'text-slate-400 hover:bg-slate-900 hover:text-slate-200',
								]}
							>
								{label}
							</a>
						))
					}
					<a
						href="/resume.pdf"
						target="_blank"
						rel="noopener noreferrer"
						class="rounded-md px-2.5 py-1.5 text-sm font-medium text-slate-400 no-underline transition-colors hover:bg-slate-900 hover:text-slate-200"
					>
						Resume
					</a>
				</nav>
			</div>
		</header>

		<main id="main" class="mx-auto w-full max-w-3xl flex-1 px-4 py-12 sm:px-6">
			<slot />
		</main>

		<footer class="mt-auto border-t border-slate-800/80 py-10">
			<div class="mx-auto max-w-3xl px-4 sm:px-6">
				<p class="text-center font-mono text-xs text-slate-500">
					© {new Date().getFullYear()} Vraj Patel · Boulder, CO
				</p>
			</div>
		</footer>
	</body>
</html>
