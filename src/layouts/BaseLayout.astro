---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Vraj Patel',
	description = 'Information Systems Engineer & Machine Learning Researcher — Boulder, CO.',
} = Astro.props;

const nav = [
	{ href: '/', label: 'Home' },
	{ href: '/experience', label: 'Experience' },
	{ href: '/projects', label: 'Projects' },
] as const;
---

<!doctype html>
<html lang="en" class="min-h-full scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body class="flex min-h-screen flex-col bg-slate-50 font-sans text-slate-900 selection:bg-blue-500/30 dark:bg-slate-950 dark:text-slate-300">
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-slate-900 focus:px-4 focus:py-2 focus:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:underline"
			>Skip to content</a
		>

		<header class="sticky top-0 z-40 w-full border-b border-slate-200 bg-white/80 backdrop-blur-xl dark:border-white/5 dark:bg-slate-950/80">
			<div class="mx-auto flex h-16 max-w-4xl items-center justify-between px-4 sm:px-6">
				<a href="/" class="group flex items-center gap-2 no-underline outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-50 rounded-md dark:focus-visible:ring-offset-slate-950">
					<span class="font-mono text-sm font-bold tracking-tight text-slate-900 dark:text-slate-200">VRAJ PATEL</span>
				</a>
				<nav aria-label="Primary" class="hidden md:flex items-center gap-1">
					{
						nav.map(({ href, label }) => (
							<a
								href={href}
								class:list={[
									'rounded-md px-3 py-2 text-sm font-medium transition-all outline-none focus-visible:ring-2 focus-visible:ring-blue-500',
									Astro.url.pathname === href || (href !== '/' && Astro.url.pathname.startsWith(href))
										? 'bg-slate-100 text-slate-900 shadow-sm ring-1 ring-slate-200 dark:bg-white/10 dark:text-white dark:ring-white/10'
										: 'text-slate-600 hover:bg-slate-50 hover:text-slate-900 dark:text-slate-400 dark:hover:bg-white/5 dark:hover:text-slate-200',
								]}
							>
								{label}
							</a>
						))
					}
					<a
						href="/resume.pdf"
						target="_blank"
						rel="noopener noreferrer"
						class="ml-2 rounded-md bg-blue-50 px-4 py-2 text-sm font-medium text-blue-700 transition-all hover:bg-blue-100 hover:text-blue-800 outline-none focus-visible:ring-2 focus-visible:ring-blue-500 ring-1 ring-blue-200 dark:bg-blue-500/10 dark:text-blue-300 dark:hover:bg-blue-500/20 dark:hover:text-blue-200 dark:ring-blue-500/20"
					>
						Resume
					</a>
				</nav>
                {/* Mobile nav simple fallback */}
                <nav class="md:hidden flex gap-3">
                    <a href="/experience" class="text-sm font-medium text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-200">Experience</a>
                    <a href="/projects" class="text-sm font-medium text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-200">Projects</a>
                    <a href="/resume.pdf" class="text-sm font-medium text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300">Resume</a>
                </nav>
			</div>
		</header>

		<main id="main" class="mx-auto w-full max-w-4xl flex-1 px-4 py-12 sm:px-6 md:py-20">
			<slot />
		</main>

		<footer class="mt-auto border-t border-slate-200 bg-slate-50/50 py-12 dark:border-white/5 dark:bg-slate-950/50">
			<div class="mx-auto flex max-w-4xl flex-col items-center justify-between gap-6 px-4 sm:flex-row sm:px-6">
				<p class="font-mono text-sm text-slate-500">
					© {new Date().getFullYear()} Vraj Patel. Boulder, CO.
				</p>
				<div class="flex gap-4">
					<a href="https://www.linkedin.com/in/vrajmp/" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-slate-300 transition-colors">
						<span class="sr-only">LinkedIn</span>
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
					</a>
                    <a href="mailto:vrajmp999@gmail.com" class="text-slate-500 hover:text-slate-300 transition-colors">
						<span class="sr-only">Email</span>
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
					</a>
				</div>
			</div>
		</footer>
	</body>
</html>