---
import type { CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'experience'>;
	variant?: 'compact' | 'detailed';
}

const { entry, variant = 'detailed' } = Astro.props;
---

{variant === 'compact' ? (
	<article class="flex flex-col items-start">
		<div class="z-10 w-full">
			<h3 class="text-base font-semibold text-slate-900 dark:text-slate-200">{entry.data.title}</h3>
			<p class="mt-1 text-sm text-blue-600 dark:text-blue-400">{entry.data.organization}</p>
			<p class="mt-1 text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide">{entry.data.period}</p>
		</div>
	</article>
) : (
	<article class="relative group">
		<span class="absolute -left-[31px] sm:-left-[39px] top-1.5 h-3 w-3 rounded-full border border-blue-500 bg-white dark:bg-slate-950 ring-4 ring-slate-50 dark:ring-slate-950 transition-transform duration-300 group-hover:scale-125"></span>
		
		<div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
			<h2 class="text-xl font-bold text-slate-900 dark:text-slate-200">{entry.data.title}</h2>
			<span class="text-sm font-medium text-slate-500 dark:text-slate-400 sm:text-right">{entry.data.period}</span>
		</div>
		
		<p class="mt-1 text-base font-medium text-blue-600 dark:text-blue-400">{entry.data.organization}</p>
		
		<div class="mt-4 text-sm leading-relaxed text-slate-700 dark:text-slate-400 [&_p]:mb-3 [&_p:last-child]:mb-0 [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:mb-3 [&_li]:mb-1 [&_a]:text-blue-600 [&_a]:underline hover:[&_a]:text-blue-800 dark:[&_a]:text-blue-400 dark:hover:[&_a]:text-blue-300">
			<slot />
		</div>
	</article>
)}
