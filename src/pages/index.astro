---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const featuredEntries = await getCollection('projects', ({ data }) => data.featured === true);
const featured = featuredEntries.sort(
	(a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

const featuredRendered = await Promise.all(
	featured.map(async (entry) => {
		const { Content } = await render(entry);
		return { entry, Content };
	}),
);
---

<BaseLayout
	title="Vraj Patel — Information Systems Engineer & ML Researcher"
	description="Information Systems Engineer & ML Researcher. M.S. Computer Science @ CU Boulder."
>
	<section class="mb-24 sm:mb-32 flex flex-col md:flex-row gap-10 items-center md:items-start" aria-labelledby="hero-heading">
		<div class="flex-1 flex flex-col gap-6">
			<h1 id="hero-heading" class="text-4xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-5xl lg:text-6xl max-w-3xl">
				I architect <span class="text-blue-600 dark:text-blue-400">reliable systems</span> at the intersection of data engineering & applied ML.
			</h1>
			<p class="mt-2 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-400 sm:text-xl">
				I'm <strong class="font-medium text-slate-900 dark:text-slate-200">Vraj Patel</strong>, an Information Systems Engineer and Machine Learning Researcher based in Boulder, CO. Currently pursuing an M.S. in Computer Science at the University of Colorado Boulder.
			</p>
			<div class="mt-4 flex flex-wrap gap-4">
				<a href="/projects" class="inline-flex items-center justify-center rounded-lg bg-slate-900 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-slate-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200">
					View Projects
				</a>
				<a href="https://www.linkedin.com/in/vrajmp/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white px-5 py-2.5 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/5 dark:text-white dark:hover:bg-white/10">
					LinkedIn
				</a>
			</div>
		</div>
		<div class="shrink-0 w-48 h-48 sm:w-64 sm:h-64 rounded-2xl overflow-hidden border border-slate-200 bg-slate-100 dark:border-white/10 dark:bg-white/5 flex items-center justify-center shadow-sm">
			<!-- Note: Add your image to public/profile.jpg (or public/profile.png) -->
			<!-- Using an absolute path starting with / looks in the public/ folder -->
			<img src="/profile.jpg" alt="Vraj Patel" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
			<div class="hidden text-slate-400 text-sm font-mono text-center p-4">Add your image at<br/>public/profile.jpg</div>
		</div>
	</section>

	<div class="grid gap-16 md:grid-cols-12 md:gap-12">
		<div class="md:col-span-4">
			<section aria-labelledby="education-heading" class="sticky top-24">
				<h2 id="education-heading" class="text-sm font-bold tracking-widest text-slate-900 dark:text-slate-200 uppercase">
					Education
				</h2>
				<ul class="mt-6 flex flex-col gap-6">
					<li class="flex flex-col items-start">
						<div class="z-10 w-full">
							<h3 class="text-base font-semibold text-slate-900 dark:text-slate-200">M.S. in Computer Science</h3>
							<p class="mt-1 text-sm text-blue-600 dark:text-blue-400">University of Colorado Boulder</p>
						</div>
					</li>
					<li class="flex flex-col items-start">
						<div class="z-10 w-full">
							<h3 class="text-base font-semibold text-slate-900 dark:text-slate-200">B.S. in Computer Science <span class="text-slate-500 font-normal block sm:inline">(Business Minor)</span></h3>
							<p class="mt-1 text-sm text-blue-600 dark:text-blue-400">University of Colorado Boulder</p>
							<p class="mt-1 text-sm text-slate-600 dark:text-slate-400">GPA 3.65/4.00 · Dean's List</p>
						</div>
					</li>
				</ul>

				<div class="mt-10">
					<h3 class="text-sm font-bold tracking-widest text-slate-900 dark:text-slate-200 uppercase mb-4">Relevant Coursework</h3>
					<div class="flex flex-wrap gap-2">
						{['Deep Learning', 'Neural Networks', 'Natural Language Processing', 'Computer Vision', 'Machine Learning', 'Advanced Data Science', 'Algorithms', 'Cybersecurity'].map(course => (
							<span class="inline-flex items-center rounded bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700 dark:bg-white/10 dark:text-slate-300">
								{course}
							</span>
						))}
					</div>
				</div>
			</section>
		</div>

		<div class="md:col-span-8">
			<section aria-labelledby="featured-heading">
				<div class="flex items-center justify-between gap-4 border-b border-slate-200 pb-4 dark:border-white/10">
					<h2 id="featured-heading" class="text-sm font-bold tracking-widest text-slate-900 dark:text-slate-200 uppercase">
						Selected Work
					</h2>
				</div>
				<div class="mt-8 flex flex-col gap-10">
					{
						featuredRendered.map(({ entry, Content }) => (
							<article class="flex flex-col items-start">
								<div class="z-10 w-full">
									<div class="flex items-center gap-3">
										<span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-medium text-blue-700 dark:bg-blue-500/10 dark:text-blue-300">
											{entry.data.domain}
										</span>
									</div>
									<h3 class="mt-3 text-xl font-bold text-slate-900 dark:text-slate-200">
										{entry.data.title}
									</h3>
									<div class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400 [&_p]:mb-3 [&_p:last-child]:mb-0">
										<Content />
									</div>
								</div>
							</article>
						))
					}
				</div>
				<div class="mt-10">
					<a href="/projects" class="group inline-flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors">
						View all projects
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				</div>
			</section>
		</div>
	</div>
</BaseLayout>
