---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import { getCollection, render } from 'astro:content';

const featuredEntries = await getCollection('projects', ({ data }) => data.featured === true);
const featured = featuredEntries.sort(
	(a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);

const featuredRendered = await Promise.all(
	featured.map(async (entry) => {
		const { Content } = await render(entry);
		return { entry, Content };
	}),
);

const expEntries = await getCollection('experience');
const recentExperience = expEntries.sort((a, b) => a.data.order - b.data.order).slice(0, 3);
---

<BaseLayout
	title="Vraj Patel — Information Systems Engineer & ML Researcher"
	description="Information Systems Engineer & ML Researcher. M.S. Computer Science @ CU Boulder."
>
	<section class="mb-24 sm:mb-32 flex flex-col items-center text-center sm:flex-row sm:text-left sm:items-center gap-10" aria-labelledby="hero-heading">
		<div class="shrink-0 w-48 h-48 sm:w-64 sm:h-64 rounded-full overflow-hidden border-4 border-white shadow-lg dark:border-slate-800 bg-slate-100 dark:bg-slate-800 flex items-center justify-center">
			<img src="/profile.JPG" alt="Vraj Patel" class="w-full h-full object-cover" />
		</div>
		<div class="flex-1 flex flex-col gap-4 items-center sm:items-start">
			<h1 id="hero-heading" class="text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white sm:text-5xl lg:text-6xl">
				Vraj Patel
			</h1>
			<p class="text-xl font-medium text-blue-600 dark:text-blue-400 sm:text-2xl">
				Systems Integration Engineer
			</p>
			<p class="max-w-2xl text-lg leading-relaxed text-slate-700 dark:text-slate-400">
				Specializing in <strong class="font-medium text-slate-900 dark:text-slate-200">Machine Learning</strong> and <strong class="font-medium text-slate-900 dark:text-slate-200">Data Engineering ETL Pipelines</strong>. I architect reliable, scalable backend systems and intelligent automation. Based in Boulder, CO. Actively seeking Fall 2026 New Grad ML Ops and Software Engineering roles.
			</p>
			<div class="mt-6 flex flex-wrap justify-center sm:justify-start gap-4">
				<a href="/projects" class="inline-flex items-center justify-center rounded-full bg-blue-600 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 dark:bg-blue-600 dark:hover:bg-blue-500 shadow-sm">
					View Projects
				</a>
				<a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 rounded-full border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 dark:border-white/10 dark:bg-white/5 dark:text-slate-300 dark:hover:bg-white/10 dark:hover:text-white shadow-sm">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
					Download Resume
				</a>
			</div>
		</div>
	</section>

	<div class="grid gap-16 md:grid-cols-12 md:gap-12">
		<div class="md:col-span-4 flex flex-col gap-16">
			<section aria-labelledby="education-heading">
				<h2 id="education-heading" class="text-sm font-bold tracking-widest text-slate-900 dark:text-slate-200 uppercase border-b border-slate-200 pb-4 dark:border-white/10">
					Education
				</h2>
				<ul class="mt-6 flex flex-col gap-6">
					<li class="flex flex-col items-start">
						<div class="z-10 w-full">
							<h3 class="text-base font-semibold text-slate-900 dark:text-slate-200">M.S. in Computer Science <span class="text-slate-500 font-normal block sm:inline">(AI Subplan)</span></h3>
							<p class="mt-1 text-sm text-blue-600 dark:text-blue-400">University of Colorado Boulder</p>
							<p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Expected Graduation: 2028</p>
						</div>
					</li>
					<li class="flex flex-col items-start">
						<div class="z-10 w-full">
							<h3 class="text-base font-semibold text-slate-900 dark:text-slate-200">B.S. in Computer Science <span class="text-slate-500 font-normal block sm:inline">(Business Minor)</span></h3>
							<p class="mt-1 text-sm text-blue-600 dark:text-blue-400">University of Colorado Boulder</p>
							<p class="mt-1 text-sm text-slate-600 dark:text-slate-400">GPA 3.65/4.00 · Dean's List</p>
						</div>
					</li>
				</ul>

				<div class="mt-8">
					<h3 class="text-sm font-bold tracking-widest text-slate-900 dark:text-slate-200 uppercase mb-4">Relevant Coursework</h3>
					<div class="flex flex-wrap gap-2">
						{['Deep Learning', 'Neural Networks', 'Natural Language Processing', 'Computer Vision', 'Machine Learning', 'Advanced Data Science', 'Algorithms', 'Cybersecurity'].map(course => (
							<span class="inline-flex items-center rounded bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700 dark:bg-white/10 dark:text-slate-300">
								{course}
							</span>
						))}
					</div>
				</div>

				<div class="mt-8 mb-12 sm:mb-0">
					<h3 class="text-sm font-bold tracking-widest text-slate-900 dark:text-slate-200 uppercase mb-4">Technical Skills</h3>
					<div class="flex flex-col gap-5">
						<div>
							<h4 class="text-xs font-semibold text-slate-700 dark:text-slate-400 mb-2 uppercase tracking-wide">Languages</h4>
							<div class="flex flex-wrap gap-2">
								{['Python', 'TypeScript', 'JavaScript', 'SQL', 'C++', 'Java'].map(skill => (
									<span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 dark:bg-blue-500/10 dark:text-blue-300 ring-1 ring-inset ring-blue-700/10 dark:ring-blue-400/20">
										{skill}
									</span>
								))}
							</div>
						</div>
						<div>
							<h4 class="text-xs font-semibold text-slate-700 dark:text-slate-400 mb-2 uppercase tracking-wide">Frameworks & Libraries</h4>
							<div class="flex flex-wrap gap-2">
								{['TensorFlow', 'PyTorch', 'Scikit-Learn', 'FastAPI', 'React', 'Astro'].map(skill => (
									<span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 dark:bg-blue-500/10 dark:text-blue-300 ring-1 ring-inset ring-blue-700/10 dark:ring-blue-400/20">
										{skill}
									</span>
								))}
							</div>
						</div>
						<div>
							<h4 class="text-xs font-semibold text-slate-700 dark:text-slate-400 mb-2 uppercase tracking-wide">Infrastructure & Tools</h4>
							<div class="flex flex-wrap gap-2">
								{['Docker', 'PostgreSQL', 'AWS', 'TrueNAS', 'Git', 'Linux'].map(skill => (
									<span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 dark:bg-blue-500/10 dark:text-blue-300 ring-1 ring-inset ring-blue-700/10 dark:ring-blue-400/20">
										{skill}
									</span>
								))}
							</div>
						</div>
					</div>
				</div>
			</section>

			<section aria-labelledby="experience-heading">
				<h2 id="experience-heading" class="text-sm font-bold tracking-widest text-slate-900 dark:text-slate-200 uppercase border-b border-slate-200 pb-4 dark:border-white/10 mb-6">
					Recent Experience
				</h2>
				<div class="flex flex-col gap-6">
					{
						recentExperience.map((entry) => (
							<ExperienceItem entry={entry} variant="compact" />
						))
					}
				</div>
				<div class="mt-6">
					<a href="/experience" class="group inline-flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors">
						View full experience
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				</div>
			</section>
		</div>

		<div class="md:col-span-8">
			<section aria-labelledby="featured-heading">
				<div class="flex items-center justify-between gap-4 border-b border-slate-200 pb-4 dark:border-white/10">
					<h2 id="featured-heading" class="text-sm font-bold tracking-widest text-slate-900 dark:text-slate-200 uppercase">
						Selected Work
					</h2>
				</div>
				<div class="mt-8 flex flex-col gap-10">
					{
						featuredRendered.map(({ entry, Content }) => (
							<ProjectCard entry={entry} showDomain={true}>
								<Content />
							</ProjectCard>
						))
					}
				</div>
				<div class="mt-10">
					<a href="/projects" class="group inline-flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors">
						View all projects
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				</div>
			</section>
		</div>
	</div>
</BaseLayout>
