---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const projectEntries = await getCollection('projects');

const projectRendered = await Promise.all(
	projectEntries.map(async (entry) => {
		const { Content } = await render(entry);
		return { entry, Content };
	}),
);

// Group projects by domain
const groupedProjects = projectRendered.reduce((acc, { entry, Content }) => {
	const domain = entry.data.domain;
	if (!acc[domain]) acc[domain] = [];
	acc[domain].push({ entry, Content });
	return acc;
}, {} as Record<string, typeof projectRendered>);

// Sort each group by order
Object.keys(groupedProjects).forEach((domain) => {
	groupedProjects[domain].sort((a, b) => (a.entry.data.order ?? 99) - (b.entry.data.order ?? 99));
});

// Domain order
const domains = ['Machine Learning', 'Systems Infrastructure', 'Software Engineering'];
---

<BaseLayout
	title="Projects — Vraj Patel"
	description="Selected projects categorized by Machine Learning, Systems Infrastructure, and Software Engineering."
>
	<div class="mb-16 border-b border-slate-200 pb-8 dark:border-white/10">
		<h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">Projects</h1>
		<p class="mt-4 text-lg text-slate-600 dark:text-slate-400">
			A selection of my technical projects ranging across ML pipelines, robust backends, and cloud infrastructure.
		</p>
	</div>

	<div class="flex flex-col gap-20">
		{
			domains.map((domain) => {
				const domainProjects = groupedProjects[domain] || [];
				if (domainProjects.length === 0) return null;

				return (
					<section>
						<h2 class="mb-6 text-xl font-bold text-slate-900 dark:text-slate-200">
							{domain}
						</h2>
						
						<div class="grid gap-6 sm:grid-cols-2">
							{domainProjects.map(({ entry, Content }) => (
								<article class="flex flex-col justify-between rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-white/10 dark:bg-white/5 transition-all hover:shadow-md">
									<div>
										<div class="flex items-start justify-between gap-4 mb-4">
											<h3 class="text-lg font-bold text-slate-900 dark:text-slate-200">
												{entry.data.title}
											</h3>
											<div class="flex items-center gap-2 shrink-0">
												{entry.data.github && (
													<a href={entry.data.github} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300">
														<span class="sr-only">GitHub</span>
														<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.24c3-.34 6-1.53 6-6.76a5.2 5.2 0 0 0-1.5-3.8 5.4 5.4 0 0 0-.15-3.8s-1.2-.38-3.9 1.4a12.8 12.8 0 0 0-7 0C6.2 2.12 5 2.5 5 2.5a5.4 5.4 0 0 0-.15 3.8A5.2 5.2 0 0 0 3 10.1c0 5.22 3 6.42 6 6.76a4.8 4.8 0 0 0-1 3.24v4"/><path d="M3 19c3 1 4-1 5-1"/></svg>
													</a>
												)}
												{entry.data.link && (
													<a href={entry.data.link} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300">
														<span class="sr-only">External Link</span>
														<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
													</a>
												)}
											</div>
										</div>
										<div class="text-sm leading-relaxed text-slate-600 dark:text-slate-400 [&_p]:mb-3 [&_p:last-child]:mb-0 [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:mb-3 [&_li]:mb-1 [&_a]:text-blue-600 [&_a]:underline hover:[&_a]:text-blue-800 dark:[&_a]:text-blue-400 dark:hover:[&_a]:text-blue-300">
											<Content />
										</div>
									</div>
									{entry.data.tech && entry.data.tech.length > 0 && (
										<div class="mt-6 flex flex-wrap gap-2">
											{entry.data.tech.map((techItem: string) => (
												<span class="inline-flex items-center rounded-md bg-slate-100 px-2 py-1 text-xs font-medium text-slate-600 dark:bg-white/5 dark:text-slate-300 ring-1 ring-inset ring-slate-200 dark:ring-white/10">
													{techItem}
												</span>
											))}
										</div>
									)}
								</article>
							))}
						</div>
					</section>
				);
			})
		}
	</div>
</BaseLayout>
