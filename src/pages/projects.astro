---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection, render } from 'astro:content';

const projectEntries = await getCollection('projects');

const projectRendered = await Promise.all(
	projectEntries.map(async (entry) => {
		const { Content } = await render(entry);
		return { entry, Content };
	}),
);

// Sort all projects by order (featured first, then by order number)
const sortedProjects = projectRendered.sort((a, b) => {
	const aFeatured = a.entry.data.featured ? 0 : 1;
	const bFeatured = b.entry.data.featured ? 0 : 1;
	if (aFeatured !== bFeatured) return aFeatured - bFeatured;
	return (a.entry.data.order ?? 99) - (b.entry.data.order ?? 99);
});
---

<BaseLayout
	title="Projects — Vraj Patel"
	description="Projects in machine learning, backend systems, infrastructure, and research — Vraj Patel."
>
	<div class="mb-16 border-b border-slate-200 pb-8 dark:border-white/10">
		<h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">Projects</h1>
		<p class="mt-4 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-400">
			A mix of production systems, research, and side projects. Click any card for the full technical detail.
		</p>
	</div>

	<div class="grid gap-6 sm:grid-cols-2">
		{
			sortedProjects.map(({ entry, Content }, index) => (
				<div class="animate-fade-in-up" style={`animation-delay: ${index * 0.05}s;`}>
					<ProjectCard entry={entry} showDomain={true}>
						<Content />
					</ProjectCard>
				</div>
			))
		}
	</div>
</BaseLayout>
