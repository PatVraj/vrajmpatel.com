---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const projectEntries = await getCollection('projects');

// Group projects by domain
const groupedProjects = projectEntries.reduce((acc, project) => {
	const domain = project.data.domain;
	if (!acc[domain]) acc[domain] = [];
	acc[domain].push(project);
	return acc;
}, {} as Record<string, typeof projectEntries>);

// Sort each group by order
Object.keys(groupedProjects).forEach((domain) => {
	groupedProjects[domain].sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
});

// Domain order
const domains = ['Machine Learning', 'Systems Infrastructure', 'Software Engineering'];
---

<BaseLayout
	title="Projects — Vraj Patel"
	description="Selected projects categorized by Machine Learning, Systems Infrastructure, and Software Engineering."
>
	<div class="mb-16">
		<h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Projects</h1>
		<p class="mt-4 text-lg text-slate-400">
			A selection of my technical projects ranging across ML pipelines, robust backends, and cloud infrastructure.
		</p>
	</div>

	<div class="flex flex-col gap-20">
		{
			domains.map((domain) => {
				const domainProjects = groupedProjects[domain] || [];
				if (domainProjects.length === 0) return null;

				return (
					<section>
						<h2 class="mb-8 flex items-center gap-3 text-lg font-semibold text-slate-200">
							<span class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/5 border border-white/10 text-indigo-400">
								{domain === 'Machine Learning' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
								)}
								{domain === 'Systems Infrastructure' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="14" rx="2"/><rect width="20" height="8" x="2" y="2" rx="2"/><line x1="6" x2="6.01" y1="18" y2="18"/><line x1="6" x2="6.01" y1="6" y2="6"/></svg>
								)}
								{domain === 'Software Engineering' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
								)}
							</span>
							{domain}
						</h2>
						
						<div class="grid gap-6 sm:grid-cols-2">
							{domainProjects.map((entry) => (
								<article class="group relative flex flex-col justify-between rounded-xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition-colors hover:bg-white/10 hover:border-white/20">
									<div>
										<h3 class="text-base font-semibold text-slate-200 group-hover:text-indigo-400 transition-colors">
											{entry.data.title}
										</h3>
										<p class="mt-3 text-sm leading-relaxed text-slate-400">
											{entry.body.trim()}
										</p>
									</div>
								</article>
							))}
						</div>
					</section>
				);
			})
		}
	</div>
</BaseLayout>
