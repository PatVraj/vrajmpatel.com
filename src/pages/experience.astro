---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const expEntries = await getCollection('experience');
const experience = expEntries.sort((a, b) => a.data.order - b.data.order);

const expRendered = await Promise.all(
	experience.map(async (entry) => {
		const { Content } = await render(entry);
		return { entry, Content };
	}),
);
---

<BaseLayout
	title="Experience — Vraj Patel"
	description="Professional experience and research roles."
>
	<div class="mb-12 border-b border-slate-200 pb-8 dark:border-white/10">
		<h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">Experience</h1>
		<p class="mt-4 text-lg text-slate-600 dark:text-slate-400">
			My professional background in software engineering, systems automation, and machine learning research.
		</p>
	</div>

	<div class="relative border-l border-slate-200 dark:border-white/10 pl-6 sm:pl-8 ml-3 sm:ml-4">
		<div class="flex flex-col gap-12">
			{
				expRendered.map(({ entry, Content }) => (
					<article class="relative group">
						<span class="absolute -left-[31px] sm:-left-[39px] top-1.5 h-3 w-3 rounded-full border border-blue-500 bg-white dark:bg-slate-950 ring-4 ring-slate-50 dark:ring-slate-950 transition-transform duration-300 group-hover:scale-125"></span>
						
						<div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
							<h2 class="text-xl font-bold text-slate-900 dark:text-slate-200">{entry.data.title}</h2>
							<span class="text-sm font-medium text-slate-500 dark:text-slate-400 sm:text-right">{entry.data.period}</span>
						</div>
						
						<p class="mt-1 text-base font-medium text-blue-600 dark:text-blue-400">{entry.data.organization}</p>
						
						<div class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 [&_p]:mb-3 [&_p:last-child]:mb-0 [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:mb-3 [&_li]:mb-1 [&_a]:text-blue-600 [&_a]:underline hover:[&_a]:text-blue-800 dark:[&_a]:text-blue-400 dark:hover:[&_a]:text-blue-300">
							<Content />
						</div>
					</article>
				))
			}
		</div>
	</div>
</BaseLayout>
