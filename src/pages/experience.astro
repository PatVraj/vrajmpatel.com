---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import { getCollection, render } from 'astro:content';

const expEntries = await getCollection('experience');
const experience = expEntries.sort((a, b) => a.data.order - b.data.order);

const expRendered = await Promise.all(
	experience.map(async (entry) => {
		const { Content } = await render(entry);
		return { entry, Content };
	}),
);
---

<BaseLayout
	title="Experience — Vraj Patel"
	description="Professional experience and research roles."
>
	<div class="mb-12 border-b border-slate-200 pb-8 dark:border-white/10">
		<h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">Experience</h1>
		<p class="mt-4 text-lg text-slate-600 dark:text-slate-400">
			My professional background in software engineering, systems automation, and machine learning research.
		</p>
	</div>

	<div class="relative border-l border-slate-200 dark:border-white/10 pl-6 sm:pl-8 ml-3 sm:ml-4">
		<div class="flex flex-col gap-12">
			{
				expRendered.map(({ entry, Content }, index) => (
					<div class="animate-fade-in-up" style={`animation-delay: ${index * 0.1}s;`}>
						<ExperienceItem entry={entry} variant="detailed">
							<Content />
						</ExperienceItem>
					</div>
				))
			}
		</div>
	</div>
</BaseLayout>
