---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExperienceItem from "../components/ExperienceItem.astro";
import { getCollection, render } from "astro:content";

const expEntries = await getCollection("experience");
const experience = expEntries.sort((a, b) => a.data.order - b.data.order);

const expRendered = await Promise.all(
  experience.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);
---

<BaseLayout
  title="Experience — Vraj Patel"
  description="Professional background of Vraj Patel — software engineering, ML research, and systems infrastructure roles. Open to SWE and ML engineering opportunities."
>
  <div class="mb-12 border-b border-slate-200 pb-8 dark:border-white/10">
    <h1
      class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl"
    >
      Experience
    </h1>
    <p class="mt-4 text-lg text-slate-600 dark:text-slate-400">
      My professional background spanning ML research, backend engineering, and
      systems infrastructure — across academia, defense, and industry.
  </div>

  <div class="relative mt-2 sm:mt-4">
    <div class="flex flex-col gap-12">
      {
        expRendered.map(({ entry, Content }, index) => (
          <div
            class="animate-fade-in-up"
            style={`animation-delay: ${index * 0.1}s;`}
          >
            <ExperienceItem entry={entry} variant="detailed">
              <Content />
            </ExperienceItem>
          </div>
        ))
      }
    </div>
  </div>
</BaseLayout>
